# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# lockfiles (bun is the source of truth)
/package-lock.json
/pnpm-lock.yaml
/yarn.lock

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# graphify knowledge graph (generated; rebuilt by post-commit hook)
/graphify-out

# Claude Code local machine settings (skills/ kept tracked)
.claude/settings.local.json
