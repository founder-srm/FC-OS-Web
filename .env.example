# --- Local self-hosting setup (branch: feat/local-self-hosting) ---
# Brought up by `supabase start`. See .self-hosting-docs/local-setup.md.

# Database — local Supabase Postgres (postgres-js driver in src/database/db.ts).
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres

# Self-hosted Better Auth.
# Signs sessions — generate with: openssl rand -base64 32  (min 32 chars)
BETTER_AUTH_SECRET=
# Public base URL of the app.
BETTER_AUTH_URL=http://localhost:3000

# OTP email delivery — Resend over SMTP.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxx_your_resend_api_key
MAIL_FROM=FC OS <no-reply@fc-os.tech>
