# Database (Neon / Postgres) — required by db.ts and drizzle.config.ts
DATABASE_URL=

# Neon Auth (Better Auth). Get NEON_AUTH_BASE_URL from `provision_neon_auth`
# output / the Neon Console (Project → Branch → Auth).
NEON_AUTH_BASE_URL=
# Signs the session cookie. Generate with: openssl rand -base64 32  (min 32 chars)
NEON_AUTH_COOKIE_SECRET=
